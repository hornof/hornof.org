---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

// F17 (E3.1): the wall is generated at build time from the `projects` content
// collection — no inlined JSON, no client-side render. getCollection() gives no
// order guarantee, so sort by the `order` stamped on each record (authored
// sequence). A new build is one object appended to content/projects/projects.json;
// zod (src/content.config.ts) type-checks it and this template renders the card.
const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

// The archives (/.20xx/) and the eclipse app (/projects/eclipse/) are static
// passthrough docs, not Astro pages — opt their links out of the SPA swap so
// they load fully (matches F16's data-astro-reload handling elsewhere).
const isPassthrough = (href: string) =>
  /(^|\/)\.20\d\d\//.test(href) || /projects\/eclipse\//.test(href);

// V3: the eclipse "Run it" link runs the sim inside the site — a lightbox over
// the wall on desktop, the full-screen link on mobile. Detect that link by its
// href (the self-contained static app at projects/eclipse/) so the card data
// stays plain; the script below upgrades it and everything degrades to the
// full-screen navigation without JS.
const isEclipseRun = (href: string) => /(^|\/)projects\/eclipse\/?$/.test(href);

// The "how it was built" line — the differentiator, shown not hidden.
function buildBits(b: {
  stack?: string;
  agents?: string;
  tests?: number | string;
  firstPassGreen?: string | boolean;
}) {
  const bits: string[] = [];
  if (b.stack) bits.push(b.stack);
  if (b.agents) bits.push(b.agents);
  if (b.tests != null) bits.push(b.tests + " tests");
  if (b.firstPassGreen) bits.push("first-pass green: " + b.firstPassGreen);
  return bits;
}
---

<MainLayout
  title="Projects — Luke Hornof"
  description="A growing wall of builds — each one documenting how it was made, which agents and models built it, and what it cost."
  bodyClass="page-fixed"
>
  {/* F17: Projects wall, rendered at build time from the projects collection.
      V2.1: shared MainLayout shell + an explicit back-link — the sidebar name
      alone didn't read as a way home, so the subpage felt stranded. */}
  <main class="projects">
    <p class="colophon-back"><a href="/">← Luke Hornof</a></p>
    <h2 class="page-title">Projects</h2>
    <p class="projects-intro">
      A growing wall of builds. Each one records how it was made — the stack, the
      agents and models, the tests, the cost — because how a thing gets built is
      half the story.
    </p>
    <p class="projects-intro">
      Everything here came out of the same loop: I write a spec and gate it,
      agents build and check each other's work, I review every pull request, and
      nothing final until the deployed result is verified. The poster is that
      machine on one page.
    </p>

    {/* The workflow poster. On desktop, clicking opens the full-size image in an
        in-site lightbox (native <dialog>) — the same pattern as the eclipse
        embed. On mobile (or without <dialog>/JS) the link falls through to the
        full-size image (data-astro-reload → a real navigation to the static
        asset, not an SPA swap). */}
    <figure class="workflow-poster">
      <a
        class="workflow-poster-open"
        href="/work/img/agentic-programming-blueprint.webp"
        data-poster-open
        data-astro-reload
        aria-haspopup="dialog"
        aria-label="Open the workflow poster at full size"
      >
        <img
          src="/work/img/agentic-programming-blueprint.webp"
          width="1600"
          height="894"
          loading="lazy"
          decoding="async"
          alt="Hand-drawn poster of the agentic programming workflow: a cast of the human director/owner and the agents — Cowork the read-only verifier, Claude Code the programmer, background workers, and a scheduled-task babysitter; the eight-stage build loop drawn as a winding road with human approval gates at the PRD and engineering doc; a panel of the loop's hard-won rules; and a shared-brain table listing the artifact files and their owners."
        />
      </a>
      <figcaption>
        The method, as a poster (generated by NotebookLM from my process guide,
        modified by Claude agents).
      </figcaption>
    </figure>

    {/* Full-size poster lightbox (desktop). Mirrors the eclipse <dialog>: native
        modal gives focus management + Esc for free; the image src is set only on
        open, so the closed dialog carries no load cost. */}
    <dialog
      class="poster-lightbox"
      aria-label="The agentic programming workflow, as a poster — full size"
    >
      <button
        type="button"
        class="poster-lightbox-close"
        aria-label="Close the poster"
      >
        <span aria-hidden="true">&times;</span>
      </button>
      <img
        class="poster-lightbox-img"
        width="1600"
        height="894"
        alt="The agentic programming workflow poster, shown at full size."
      />
    </dialog>

    <div class="projects-list" id="projects-list">
      {
        projects.map((entry) => {
          const d = entry.data;
          const b = d.build || {};
          const bits = buildBits(b);
          return (
            <article class="project-card" data-slug={d.slug}>
              <div class="project-head">
                <h2 class="project-title">{d.title}</h2>
                {d.date && <span class="project-date">{d.date}</span>}
              </div>
              {d.blurb && <p class="project-blurb">{d.blurb}</p>}
              {b.stack && (
                <p class="project-build">
                  <span class="project-build-label">Built with </span>{bits.join(" · ")}{b.costNote && <span class="project-cost">{b.costNote}</span>}
                </p>
              )}
              {d.links.length > 0 && (
                <nav class="project-links" aria-label={`${d.title} links`}>
                  {d.links.map((l) => (
                    <a
                      href={l.href}
                      data-astro-reload={isPassthrough(l.href) ? "" : undefined}
                      data-eclipse-run={isEclipseRun(l.href) ? "" : undefined}
                      aria-haspopup={isEclipseRun(l.href) ? "dialog" : undefined}
                    >{l.label}</a>
                  ))}
                </nav>
              )}
            </article>
          );
        })
      }
    </div>

    {/* V3: the eclipse sim runs inside the site. A native modal <dialog> gives
        focus management + Esc close for free; the iframe's src is set only when
        the lightbox opens (never on page load), so the wall carries no iframe
        cost and Lighthouse holds. "Open full screen ↗" stays as the external
        route — and is the mobile fallback (below the wall breakpoint the "Run
        it" action IS this full-screen link, not the cramped pane). */}
    <dialog
      class="eclipse-lightbox"
      aria-label="eclipse-sim — interactive solar-system orrery"
    >
      <div class="eclipse-lightbox-bar">
        <span class="eclipse-lightbox-title">eclipse-sim</span>
        <a
          class="eclipse-lightbox-fullscreen"
          href="projects/eclipse/"
          data-astro-reload
        >Open full screen &#8599;</a>
        <button
          type="button"
          class="eclipse-lightbox-close"
          aria-label="Close the eclipse-sim lightbox"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <iframe
        class="eclipse-lightbox-frame"
        title="eclipse-sim — interactive solar-system orrery"
        loading="lazy"></iframe>
    </dialog>
  </main>

  <script>
    // V3: run the eclipse sim inside the site. On desktop "Run it" opens the
    // lightbox <dialog> with an iframe of the self-contained app; on mobile (or
    // without <dialog> support / JS) the link falls through to the full-screen
    // route. Re-wired on astro:page-load so it survives view-transition swaps;
    // the dialog + link are re-rendered per navigation, so listeners never stack.
    const SIM_SRC = "/projects/eclipse/";
    const isDesktop = () => window.matchMedia("(min-width: 880px)").matches;

    function initEclipseLightbox() {
      const dialog = document.querySelector<HTMLDialogElement>(".eclipse-lightbox");
      const runLinks = document.querySelectorAll<HTMLAnchorElement>(
        "[data-eclipse-run]"
      );
      if (!dialog || !runLinks.length) return;

      const frame = dialog.querySelector<HTMLIFrameElement>(".eclipse-lightbox-frame");
      const closeBtn = dialog.querySelector<HTMLButtonElement>(
        ".eclipse-lightbox-close"
      );
      let trigger: HTMLElement | null = null;

      function openLightbox(t: HTMLElement) {
        trigger = t;
        // Load the sim only now (keeps it off the wall's initial load).
        if (frame && frame.getAttribute("src") !== SIM_SRC) {
          frame.setAttribute("src", SIM_SRC);
        }
        dialog!.showModal();
      }

      runLinks.forEach((link) => {
        link.addEventListener("click", (e) => {
          // Mobile → let the link navigate to the full-screen sim.
          if (!isDesktop()) return;
          // No native modal support → same full-screen fallback.
          if (typeof dialog!.showModal !== "function") return;
          e.preventDefault();
          openLightbox(link);
        });
      });

      if (closeBtn) {
        closeBtn.addEventListener("click", () => {
          if (dialog.open) dialog.close();
        });
      }

      // Click on the backdrop (outside the dialog box) closes it.
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog && dialog.open) dialog.close();
      });

      // close fires for Esc, the close button, and the backdrop — stop the sim
      // (drop the src so it isn't running in the background) and return focus.
      dialog.addEventListener("close", () => {
        if (frame) frame.removeAttribute("src");
        if (trigger && typeof trigger.focus === "function") trigger.focus();
        trigger = null;
      });
    }

    document.addEventListener("astro:page-load", initEclipseLightbox);
  </script>

  <script>
    // The workflow-poster lightbox — same shape as the eclipse embed above. On
    // desktop, clicking the poster opens the full-size image in a native <dialog>
    // over the dimmed wall; on mobile (or without <dialog>/JS) the link falls
    // through to the full-size image. Re-wired on astro:page-load so it survives
    // view-transition swaps; the dialog + link are re-rendered per navigation, so
    // listeners never stack. (This block is a separate module, so it needs its own
    // isDesktop.)
    const posterIsDesktop = () =>
      window.matchMedia("(min-width: 880px)").matches;

    function initPosterLightbox() {
      const dialog = document.querySelector<HTMLDialogElement>(".poster-lightbox");
      const openers = document.querySelectorAll<HTMLAnchorElement>(
        "[data-poster-open]"
      );
      if (!dialog || !openers.length) return;

      const img = dialog.querySelector<HTMLImageElement>(".poster-lightbox-img");
      const closeBtn = dialog.querySelector<HTMLButtonElement>(
        ".poster-lightbox-close"
      );
      let trigger: HTMLElement | null = null;

      function open(link: HTMLAnchorElement) {
        trigger = link;
        // Load the full-size image only now (keeps the closed dialog free of any
        // load cost so Lighthouse holds). Same URL as the inline poster, so it's
        // already cached — no extra request.
        const src = link.getAttribute("href");
        if (img && src && img.getAttribute("src") !== src) {
          img.setAttribute("src", src);
        }
        dialog!.showModal();
      }

      openers.forEach((link) => {
        link.addEventListener("click", (e) => {
          // Mobile → let the link navigate to the full-size image.
          if (!posterIsDesktop()) return;
          // No native modal support → same full-size fallback.
          if (typeof dialog!.showModal !== "function") return;
          e.preventDefault();
          open(link);
        });
      });

      if (closeBtn) {
        closeBtn.addEventListener("click", () => {
          if (dialog.open) dialog.close();
        });
      }

      // Click on the backdrop (outside the image) closes it.
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog && dialog.open) dialog.close();
      });

      // close fires for Esc, the close button, and the backdrop — return focus
      // to the poster that opened it.
      dialog.addEventListener("close", () => {
        if (trigger && typeof trigger.focus === "function") trigger.focus();
        trigger = null;
      });
    }

    document.addEventListener("astro:page-load", initPosterLightbox);
  </script>
</MainLayout>
