---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

// F17 (E3.1): the CV sections are data now — typed content collections rendered
// at build time. getCollection() gives no order guarantee, so sort on the
// authored `order`. The prose sections (About, the Projects teaser) stay inline;
// only the list-shaped content moved to collections.
const experience = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order
);
const publications = (await getCollection("publications")).sort(
  (a, b) => a.data.order - b.data.order
);
const talks = (await getCollection("talks")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<MainLayout
  title="Luke Hornof"
  description="Luke Hornof — AI Engineering & Leadership. Founder, researcher, and software engineer."
>
  {/* V2: the sidebar now lives in MainLayout (persistent site-wide). This page
      renders only its content column into the shared shell's slot. */}
  {/* Section copy is the source in content/*.md, inlined here by hand. */}
  <main class="content">
    <section id="about">
      <h2>About</h2>
      <p>
        AI is changing how engineering teams are built and run, and the
        companies that adapt fastest will pull ahead. The best engineering
        leaders will combine traditional management with their own hands-on
        agentic engineering.
      </p>
      <p>
        I've built and managed engineering organizations for over a decade —
        finding great engineers, creating a culture where they do their best
        work, and scaling teams that consistently ship.
      </p>
      <p>
        At Nervana, I founded the software team from scratch and grew it to 10
        engineers. After the Intel acquisition, I scaled the team to 150
        across the US, Poland, India, and Israel — without losing the quality
        and culture that made us worth acquiring. As co-founder of Luminide, I
        led product, engineering, and go-to-market — through acquisition by
        Akridata. Most recently, as CTO at ThirdLaw, I built runtime safety
        and observability for LLM and agent behavior.
      </p>
      <p>
        Underneath it all: 20+ years of hands-on engineering and research, a
        Ph.D. in CS, and published work at NeurIPS. I know how engineers think
        because I am one — these days, an agentic one.
      </p>
    </section>

    <section id="experience">
      <h2>Experience</h2>
      <ul class="cv">
        {
          experience.map((e) => (
            <li>
              <span class="cv-role">{e.data.role}, {e.data.org}</span>
              <span class="cv-when">{e.data.when}</span><span class="cv-what">{e.data.what}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section id="publications">
      <h2>Publications &amp; Patents</h2>
      <ul class="pubs">
        {
          publications.map((p) => (
            <li>
              <a href={p.data.href}>{p.data.title}</a> — {p.data.cite}
            </li>
          ))
        }
      </ul>
      <p class="more">
        <a href="https://scholar.google.com/citations?user=Al_FuxQAAAAJ"
          >Complete list on Google Scholar &rarr;</a
        >
      </p>
    </section>

    <section id="talks">
      <h2>Talks</h2>
      <p>
        Speaking on engineering leadership and building in the AI era, at SF AI
        meetups and founder events. Recent topics:
      </p>
      <ul class="talks">
        {talks.map((t) => <li>{t.data.title}</li>)}
      </ul>
    </section>

    <section id="projects">
      <h2>Projects</h2>
      <p>
        A growing wall of builds — each one documenting how it was made: the
        stack, the agents and models, the tests, the cost. This site is the
        first entry; eclipse-sim, a from-scratch eclipse predictor built
        overnight, is the second.
      </p>
      <p class="more"><a href="projects.html">See all projects &rarr;</a></p>
    </section>

    {/* F9: Breton Easter egg — a quiet sign-off dropped into the trailing
        space below the last section. A faint fleur-de-lis; click reveals a nod
        to Brittany, France, where Luke earned his PhD. Same subtle register as
        the Tardis. */}
    <footer class="page-sign-off">
      <span class="breton">
        <button
          type="button"
          class="breton-toggle"
          aria-expanded="false"
          aria-controls="breton-panel"
          aria-label="A small nod to Brittany, France"
        >
          <span aria-hidden="true">&#9884;</span>
        </button>
        <span id="breton-panel" class="breton-panel" hidden>
          <span
            class="gwenn-ha-du"
            role="img"
            aria-label="Gwenn ha Du, the flag of Brittany"></span>
          <span class="breton-text" lang="br"
            >Breizh atav — <span lang="en">a corner of Brittany, France.</span
            ></span
          >
        </span>
      </span>
    </footer>
  </main>

  <script>
    // Home-only Easter egg: the Breton sign-off. (The Tardis moved to MainLayout in
    // V2.1 so it's site-wide; the sidebar scroll-spy moved there in V2.)
    //
    // F16: under the ClientRouter these run on first load AND must re-run after a
    // view-transition swap brings the home page back (Astro doesn't re-execute
    // module scripts; astro:page-load fires on first load and after every swap).
    // Each disclosure keeps its document-level listeners in a module slot and
    // removes the previous pair before re-binding, so navigating away and back
    // never stacks duplicate handlers or leaves them pointing at detached nodes.

    // F9: Breton Easter egg — a faint fleur-de-lis revealing a nod to Brittany.
    // Same disclosure pattern as the Tardis (open/close, Escape, outside-click).
    let bretonKeydown: ((e: KeyboardEvent) => void) | null = null;
    let bretonDocClick: ((e: MouseEvent) => void) | null = null;
    function initBreton() {
      const toggle = document.querySelector(".breton-toggle");
      const panel = document.getElementById("breton-panel");
      if (!toggle || !panel) return;

      function isOpen() {
        return toggle!.getAttribute("aria-expanded") === "true";
      }
      function open() {
        panel!.hidden = false;
        toggle!.setAttribute("aria-expanded", "true");
      }
      function close(returnFocus: boolean) {
        panel!.hidden = true;
        toggle!.setAttribute("aria-expanded", "false");
        if (returnFocus) (toggle as HTMLElement).focus();
      }

      toggle.addEventListener("click", function () {
        if (isOpen()) close(false);
        else open();
      });
      if (bretonKeydown) document.removeEventListener("keydown", bretonKeydown);
      if (bretonDocClick) document.removeEventListener("click", bretonDocClick);
      bretonKeydown = function (e) {
        if (e.key === "Escape" && isOpen()) close(true);
      };
      bretonDocClick = function (e) {
        if (isOpen() && !(e.target as Element).closest(".breton")) close(false);
      };
      document.addEventListener("keydown", bretonKeydown);
      document.addEventListener("click", bretonDocClick);
    }

    function initEggs() {
      initBreton();
    }

    // astro:page-load fires on the first full load and after every swap, on the
    // fresh DOM — the correct single hook (the teardown inside each init keeps
    // document-level listeners from stacking across navigations).
    document.addEventListener("astro:page-load", initEggs);
  </script>
</MainLayout>
