---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// F17 (E3.1): the CV sections are data now — typed content collections rendered
// at build time. getCollection() gives no order guarantee, so sort on the
// authored `order`. The prose sections (About, the Projects teaser) stay inline;
// only the list-shaped content moved to collections.
const experience = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order
);
const publications = (await getCollection("publications")).sort(
  (a, b) => a.data.order - b.data.order
);
const talks = (await getCollection("talks")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Luke Hornof"
  description="Luke Hornof — AI Engineering & Leadership. Founder, researcher, and software engineer."
>
  <div class="layout">
    <header class="sidebar">
      <div class="intro">
        <h1 class="name">Luke Hornof</h1>
        <p class="tagline">AI Engineering Leader</p>
        <p class="positioning">Founder, researcher, agentic engineer.</p>
        <p class="positioning">
          Vision: amazing teams, successful products, happy customers.
        </p>
      </div>

      <nav class="section-nav" aria-label="Sections">
        <a href="#about">About</a>
        <a href="#experience">Experience</a>
        <a href="#publications">Publications</a>
        <a href="#talks">Talks</a>
        <a href="#projects">Projects</a>
      </nav>

      <nav class="social" aria-label="Social profiles">
        <a href="https://www.linkedin.com/in/lukehornof" aria-label="LinkedIn">
          <img src="work/img/linkedin-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a
          href="https://scholar.google.com/citations?user=Al_FuxQAAAAJ"
          aria-label="Google Scholar"
        >
          <img src="work/img/google-scholar-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://x.com/hornof/" aria-label="X">
          <img src="work/img/x-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://github.com/hornof/" aria-label="GitHub">
          <img src="work/img/github-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://facebook.com/lukehornof/" aria-label="Facebook">
          <img src="work/img/facebook-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://instagram.com/lukehornof/" aria-label="Instagram">
          <img src="work/img/instagram-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://soundcloud.com/luke-hornof" aria-label="SoundCloud">
          <img src="work/img/soundcloud-icon-brown.png" alt="" width="24" height="24" />
        </a>
      </nav>
    </header>

    {/* Section copy is the source in content/*.md, inlined here by hand. */}
    <main class="content">
      <section id="about">
        <h2>About</h2>
        <p>
          AI is changing how engineering teams are built and run, and the
          companies that adapt fastest will pull ahead. The best engineering
          leaders will combine traditional management with their own hands-on
          agentic engineering.
        </p>
        <p>
          I've built and managed engineering organizations for over a decade —
          finding great engineers, creating a culture where they do their best
          work, and scaling teams that consistently ship.
        </p>
        <p>
          At Nervana, I founded the software team from scratch and grew it to 10
          engineers. After the Intel acquisition, I scaled the team to 150
          across the US, Poland, India, and Israel — without losing the quality
          and culture that made us worth acquiring. As co-founder of Luminide, I
          led product, engineering, and go-to-market — through acquisition by
          Akridata. Most recently, as CTO at ThirdLaw, I built runtime safety
          and observability for LLM and agent behavior.
        </p>
        <p>
          Underneath it all: 20+ years of hands-on engineering and research, a
          Ph.D. in CS, and published work at NeurIPS. I know how engineers think
          because I am one — these days, an agentic one.
        </p>
      </section>

      <section id="experience">
        <h2>Experience</h2>
        <ul class="cv">
          {
            experience.map((e) => (
              <li>
                <span class="cv-role">{e.data.role}, {e.data.org}</span>
                <span class="cv-when">{e.data.when}</span><span class="cv-what">{e.data.what}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <section id="publications">
        <h2>Publications &amp; Patents</h2>
        <ul class="pubs">
          {
            publications.map((p) => (
              <li>
                <a href={p.data.href}>{p.data.title}</a> — {p.data.cite}
              </li>
            ))
          }
        </ul>
        <p class="more">
          <a href="https://scholar.google.com/citations?user=Al_FuxQAAAAJ"
            >Complete list on Google Scholar &rarr;</a
          >
        </p>
      </section>

      <section id="talks">
        <h2>Talks</h2>
        <p>
          Speaking on engineering leadership and building in the AI era, at SF AI
          meetups and founder events. Recent topics:
        </p>
        <ul class="talks">
          {talks.map((t) => <li>{t.data.title}</li>)}
        </ul>
      </section>

      <section id="projects">
        <h2>Projects</h2>
        <p>
          A growing wall of builds — each one documenting how it was made: the
          stack, the agents and models, the tests, the cost. This site is the
          first entry; eclipse-sim, a from-scratch eclipse predictor built
          overnight, is the second.
        </p>
        <p class="more"><a href="projects.html">See all projects &rarr;</a></p>
      </section>

      {/* F9: Breton Easter egg — a quiet sign-off dropped into the trailing
          space below the last section. A faint fleur-de-lis; click reveals a nod
          to Brittany, France, where Luke earned his PhD. Same subtle register as
          the Tardis. */}
      <footer class="page-sign-off">
        <span class="breton">
          <button
            type="button"
            class="breton-toggle"
            aria-expanded="false"
            aria-controls="breton-panel"
            aria-label="A small nod to Brittany, France"
          >
            <span aria-hidden="true">&#9884;</span>
          </button>
          <span id="breton-panel" class="breton-panel" hidden>
            <span
              class="gwenn-ha-du"
              role="img"
              aria-label="Gwenn ha Du, the flag of Brittany"></span>
            <span class="breton-text" lang="br"
              >Breizh atav — <span lang="en">a corner of Brittany, France.</span
              ></span
            >
          </span>
        </span>
      </footer>
    </main>
  </div>

  {/* Tardis time-machine: a subtle Easter-egg control linking the archives. */}
  <div class="tardis">
    <button
      type="button"
      class="tardis-toggle"
      aria-expanded="false"
      aria-controls="tardis-panel"
      aria-label="Time machine — browse earlier versions of this site"
    >
      <span class="tardis-label" aria-hidden="true">Click to time travel!</span>
      {/* Tardis (Doctor Who police box), original SVG — homage to the spinning
          Tardis on brittanychiang.com's archive control. */}
      <svg
        class="tardis-svg"
        viewBox="0 0 44 64"
        width="40"
        height="58"
        aria-hidden="true"
        focusable="false"
      >
        <rect class="td-lamp" x="20" y="2" width="4" height="4" rx="1"></rect>
        <rect class="td-dark" x="21" y="5" width="2" height="3"></rect>
        <rect class="td-roof" x="9" y="6" width="26" height="3" rx="1"></rect>
        <rect class="td-dark" x="6" y="8" width="32" height="6" rx="1"></rect>
        <rect class="td-body" x="8" y="14" width="28" height="47"></rect>
        <rect class="td-dark" x="8" y="14" width="28" height="5"></rect>
        <rect class="td-window" x="11" y="22" width="9" height="9"></rect>
        <rect class="td-window" x="24" y="22" width="9" height="9"></rect>
        <line class="td-line" x1="15.5" y1="22" x2="15.5" y2="31"></line>
        <line class="td-line" x1="28.5" y1="22" x2="28.5" y2="31"></line>
        <line class="td-line" x1="11" y1="26.5" x2="20" y2="26.5"></line>
        <line class="td-line" x1="24" y1="26.5" x2="33" y2="26.5"></line>
        <line class="td-line td-door" x1="22" y1="19" x2="22" y2="61"></line>
        <rect class="td-panel" x="11" y="35" width="9" height="22"></rect>
        <rect class="td-panel" x="24" y="35" width="9" height="22"></rect>
        <rect class="td-dark" x="6" y="60" width="32" height="3" rx="1"></rect>
      </svg>
    </button>
    <ul id="tardis-panel" class="tardis-panel" hidden>
      {/* F16: data-astro-reload — the archives are static passthrough docs, not
          Astro pages, so opt out of the SPA swap and do a real navigation. */}
      <li><a href="/.2013/" data-astro-reload>2013</a></li>
      <li><a href="/.2025/" data-astro-reload>2025</a></li>
    </ul>
  </div>

  <script>
    // The three interactive home-page behaviors, ported from main.js:
    // the Tardis time-machine, the Breton egg, and the scroll-spy nav.
    //
    // F16: under the ClientRouter these run once on first load AND must re-run
    // after every view-transition swap (Astro doesn't re-execute module scripts;
    // it fires astro:after-swap on the fresh DOM instead). Each disclosure keeps
    // its document-level listeners in a module slot and removes the previous pair
    // before re-binding, so navigating away and back never stacks duplicate
    // handlers or leaves them pointing at detached nodes.

    // F4: Tardis time-machine — a subtle control revealing links to the archives.
    let tardisKeydown: ((e: KeyboardEvent) => void) | null = null;
    let tardisDocClick: ((e: MouseEvent) => void) | null = null;
    function initTardis() {
      const toggle = document.querySelector(".tardis-toggle");
      const panel = document.getElementById("tardis-panel");
      if (!toggle || !panel) return;

      function isOpen() {
        return toggle!.getAttribute("aria-expanded") === "true";
      }
      function open() {
        panel!.hidden = false;
        toggle!.setAttribute("aria-expanded", "true");
      }
      function close(returnFocus: boolean) {
        panel!.hidden = true;
        toggle!.setAttribute("aria-expanded", "false");
        if (returnFocus) (toggle as HTMLElement).focus();
      }

      toggle.addEventListener("click", function () {
        if (isOpen()) close(false);
        else open();
      });
      if (tardisKeydown) document.removeEventListener("keydown", tardisKeydown);
      if (tardisDocClick) document.removeEventListener("click", tardisDocClick);
      tardisKeydown = function (e) {
        if (e.key === "Escape" && isOpen()) close(true);
      };
      tardisDocClick = function (e) {
        if (isOpen() && !(e.target as Element).closest(".tardis")) close(false);
      };
      document.addEventListener("keydown", tardisKeydown);
      document.addEventListener("click", tardisDocClick);
    }

    // F9: Breton Easter egg — a faint fleur-de-lis revealing a nod to Brittany.
    // Same disclosure pattern as the Tardis (open/close, Escape, outside-click).
    let bretonKeydown: ((e: KeyboardEvent) => void) | null = null;
    let bretonDocClick: ((e: MouseEvent) => void) | null = null;
    function initBreton() {
      const toggle = document.querySelector(".breton-toggle");
      const panel = document.getElementById("breton-panel");
      if (!toggle || !panel) return;

      function isOpen() {
        return toggle!.getAttribute("aria-expanded") === "true";
      }
      function open() {
        panel!.hidden = false;
        toggle!.setAttribute("aria-expanded", "true");
      }
      function close(returnFocus: boolean) {
        panel!.hidden = true;
        toggle!.setAttribute("aria-expanded", "false");
        if (returnFocus) (toggle as HTMLElement).focus();
      }

      toggle.addEventListener("click", function () {
        if (isOpen()) close(false);
        else open();
      });
      if (bretonKeydown) document.removeEventListener("keydown", bretonKeydown);
      if (bretonDocClick) document.removeEventListener("click", bretonDocClick);
      bretonKeydown = function (e) {
        if (e.key === "Escape" && isOpen()) close(true);
      };
      bretonDocClick = function (e) {
        if (isOpen() && !(e.target as Element).closest(".breton")) close(false);
      };
      document.addEventListener("keydown", bretonKeydown);
      document.addEventListener("click", bretonDocClick);
    }

    // F5: scroll-spy — highlight the nav link for the section currently in view.
    // F16: module slots hold the live observer + scroll target so a re-init tears
    // the previous ones down before rebuilding against the swapped-in sections.
    let spyObserver: IntersectionObserver | null = null;
    let spyScrollTarget: (Element | Window) | null = null;
    let spyOnScroll: (() => void) | null = null;
    let spyWindowBound = false;
    function initScrollSpy() {
      // Only in-page anchors take part in scroll-spy; page links (e.g. Projects)
      // are skipped so they never get a scroll-spy target lookup.
      const links = Array.prototype.slice
        .call(document.querySelectorAll(".section-nav a"))
        .filter(function (a) {
          const href = a.getAttribute("href");
          return href && href.charAt(0) === "#";
        });
      if (!links.length) return;

      const sections = links
        .map(function (a) {
          return document.querySelector(a.getAttribute("href"));
        })
        .filter(Boolean);
      if (!sections.length) return;

      function setActive(id) {
        links.forEach(function (a) {
          const on = a.getAttribute("href") === "#" + id;
          a.classList.toggle("active", on);
          if (on) a.setAttribute("aria-current", "true");
          else a.removeAttribute("aria-current");
        });
      }

      // On desktop the content panel scrolls internally (fixed-height frame); on
      // mobile the page scrolls. Spy against whichever is the real scroll box.
      const container = scrollContainer();

      // A thin band a bit above the middle of the scroll box is the "spy line":
      // the section crossing it is the active one. F16: disconnect any observer
      // left over from a prior page so it doesn't keep firing on detached nodes.
      if (spyObserver) spyObserver.disconnect();
      if ("IntersectionObserver" in window) {
        spyObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) setActive((entry.target as HTMLElement).id);
            });
          },
          { root: container, rootMargin: "-40% 0px -55% 0px", threshold: 0 }
        );
        sections.forEach(function (s) {
          spyObserver!.observe(s as Element);
        });
      }

      // Guard the extremes so the first/last section win at the very top/bottom,
      // where the spy line may sit past the edge of the scroll box.
      const last = sections[sections.length - 1];
      const first = sections[0];
      function edgeGuard() {
        // Recompute the scroll box each call so this stays correct across the
        // mobile/desktop breakpoint (the page scrolls on mobile, the pane on desktop).
        const box = scrollContainer();
        let atBottom, atTop;
        if (box) {
          atBottom = box.scrollTop + box.clientHeight >= box.scrollHeight - 2;
          atTop = box.scrollTop <= 2;
        } else {
          const doc = document.documentElement;
          atBottom = window.innerHeight + window.scrollY >= doc.scrollHeight - 2;
          atTop = window.scrollY <= 2;
        }
        if (atBottom) setActive(last.id);
        else if (atTop) setActive(first.id);
      }
      // F16: drop the previous scroll listener (its target may now be detached)
      // before binding the current scroll box.
      if (spyScrollTarget && spyOnScroll) {
        spyScrollTarget.removeEventListener("scroll", spyOnScroll);
      }
      spyScrollTarget = container || window;
      spyOnScroll = edgeGuard;
      spyScrollTarget.addEventListener("scroll", spyOnScroll, { passive: true });
      edgeGuard(); // initial state
      // Re-assert once the layout settles and on resize. On mobile the tall sidebar
      // pushes every section below the spy band at the top, so the observer alone
      // (which only sets on intersect, never clears) can leave a stale link lit
      // until the first scroll. The load/resize passes correct that. edgeGuard
      // re-reads the scroll box each call, so these window-level listeners are
      // bound once (F16: guarded) and stay correct across navigations.
      if (!spyWindowBound) {
        spyWindowBound = true;
        window.addEventListener("load", function () {
          if (spyOnScroll) spyOnScroll();
        });
        window.addEventListener(
          "resize",
          function () {
            if (spyOnScroll) spyOnScroll();
          },
          { passive: true }
        );
      }
    }

    // The scrollable ancestor of the sections, or null when the page itself
    // scrolls (mobile). Desktop gives .content overflow-y:auto + a fixed height.
    function scrollContainer() {
      const content = document.querySelector(".content");
      if (!content) return null;
      const oy = getComputedStyle(content).overflowY;
      if (
        (oy === "auto" || oy === "scroll") &&
        content.scrollHeight > content.clientHeight + 4
      ) {
        return content;
      }
      return null;
    }

    function init() {
      initTardis();
      initBreton();
      initScrollSpy();
    }

    // First, full page load (module scripts are deferred, so the DOM is ready).
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
    // F16: re-init after a view-transition swap brings the home page back. Astro
    // fires astro:after-swap only on SPA swaps (never on the first load), so this
    // rebuilds against the fresh DOM without double-binding on the initial load.
    // The teardown inside each init keeps document/scroll listeners from stacking.
    document.addEventListener("astro:after-swap", init);
  </script>
</BaseLayout>
