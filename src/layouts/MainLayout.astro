---
// V2 — the site-wide shell: the persistent identity/nav sidebar + the routed
// page's content. Composes BaseLayout (the pure document shell) so BaseLayout
// stays responsible only for <head>, the panorama, and the theme toggle.
//
// The sidebar is marked transition:persist="sidebar" and its SSR markup is
// byte-identical on every route (no per-page active class in the HTML — active
// state is applied client-side after load). Because every page renders the same
// sidebar node, the persisted node carries across each view-transition swap and
// never re-mounts or flashes.
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  /** Passed through to BaseLayout for the document-level asset hrefs. */
  assetBase?: string;
  noindex?: boolean;
}

const { title, description, bodyClass, assetBase = "", noindex = false } =
  Astro.props;

// Every real page is served from the site root, so the sidebar's own asset
// hrefs are absolute ("/work/img/…"). Absolute keeps the sidebar SSR markup
// identical on every route — including 404, which a host may serve under any
// path — so the persisted node always matches.
---

<BaseLayout
  title={title}
  description={description}
  bodyClass={bodyClass}
  assetBase={assetBase}
  noindex={noindex}
>
  <div class="layout">
    {/* Persistent identity/nav sidebar — identical on every route, persisted so
        it never re-renders or flashes on navigation. No active class in the SSR
        markup; the script below applies it client-side per route. */}
    <header class="sidebar" transition:persist="sidebar">
      <div class="intro">
        <h1 class="name"><a href="/">Luke Hornof</a></h1>
        <p class="tagline">AI Engineering Leader</p>
        <p class="positioning">Founder, researcher, agentic engineer.</p>
        <p class="positioning">
          Vision: amazing teams, successful products, happy customers.
        </p>
      </div>

      <nav class="section-nav" aria-label="Sections">
        <a href="/#about">About</a>
        <a href="/#experience">Experience</a>
        <a href="/#publications">Publications</a>
        <a href="/#talks">Talks</a>
        <a href="/#projects">Projects</a>
      </nav>

      <nav class="social" aria-label="Social profiles">
        <a href="https://www.linkedin.com/in/lukehornof" aria-label="LinkedIn">
          <img src="/work/img/linkedin-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a
          href="https://scholar.google.com/citations?user=Al_FuxQAAAAJ"
          aria-label="Google Scholar"
        >
          <img src="/work/img/google-scholar-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://x.com/hornof/" aria-label="X">
          <img src="/work/img/x-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://github.com/hornof/" aria-label="GitHub">
          <img src="/work/img/github-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://facebook.com/lukehornof/" aria-label="Facebook">
          <img src="/work/img/facebook-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://instagram.com/lukehornof/" aria-label="Instagram">
          <img src="/work/img/instagram-icon-brown.png" alt="" width="24" height="24" />
        </a>
        <a href="https://soundcloud.com/luke-hornof" aria-label="SoundCloud">
          <img src="/work/img/soundcloud-icon-brown.png" alt="" width="24" height="24" />
        </a>
      </nav>
    </header>

    <slot />
  </div>

  {/* Tardis time-machine — site-wide Easter egg linking the archives. V2.1: moved
      here from index so it appears on every page. transition:persist keeps the same
      node across navigations; the spin (WAAPI, in the script below) keeps its phase
      so it never jumps between pages. position:fixed, so it's outside the grid. */}
  <div class="tardis" transition:persist="tardis">
    <button
      type="button"
      class="tardis-toggle"
      aria-expanded="false"
      aria-controls="tardis-panel"
      aria-label="Time machine — browse earlier versions of this site"
    >
      <span class="tardis-label" aria-hidden="true">Click to time travel!</span>
      <svg
        class="tardis-svg"
        viewBox="0 0 44 64"
        width="40"
        height="58"
        aria-hidden="true"
        focusable="false"
      >
        <rect class="td-lamp" x="20" y="2" width="4" height="4" rx="1"></rect>
        <rect class="td-dark" x="21" y="5" width="2" height="3"></rect>
        <rect class="td-roof" x="9" y="6" width="26" height="3" rx="1"></rect>
        <rect class="td-dark" x="6" y="8" width="32" height="6" rx="1"></rect>
        <rect class="td-body" x="8" y="14" width="28" height="47"></rect>
        <rect class="td-dark" x="8" y="14" width="28" height="5"></rect>
        <rect class="td-window" x="11" y="22" width="9" height="9"></rect>
        <rect class="td-window" x="24" y="22" width="9" height="9"></rect>
        <line class="td-line" x1="15.5" y1="22" x2="15.5" y2="31"></line>
        <line class="td-line" x1="28.5" y1="22" x2="28.5" y2="31"></line>
        <line class="td-line" x1="11" y1="26.5" x2="20" y2="26.5"></line>
        <line class="td-line" x1="24" y1="26.5" x2="33" y2="26.5"></line>
        <line class="td-line td-door" x1="22" y1="19" x2="22" y2="61"></line>
        <rect class="td-panel" x="11" y="35" width="9" height="22"></rect>
        <rect class="td-panel" x="24" y="35" width="9" height="22"></rect>
        <rect class="td-dark" x="6" y="60" width="32" height="3" rx="1"></rect>
      </svg>
    </button>
    <ul id="tardis-panel" class="tardis-panel" hidden>
      {/* data-astro-reload — the archives are static passthrough docs, not Astro
          pages, so opt out of the SPA swap and do a real navigation. */}
      <li><a href="/.2013/" data-astro-reload>2013</a></li>
      <li><a href="/.2025/" data-astro-reload>2025</a></li>
    </ul>
  </div>

  <script>
    // V2 — sidebar nav active state, driven by astro:page-load so it runs on the
    // first load AND after every view-transition swap (module scripts don't
    // re-execute on swap; the F16 lesson). The sidebar node itself is persisted,
    // so this only re-computes which link is marked — it never rebuilds the DOM.
    //
    //   /            → scroll-spy over the home sections.
    //   /projects.html, /built-with.html, /eclipse-built.html
    //                → mark "Projects" current (these are Projects-area pages).
    //   anything else (404) → no link marked.

    // Live scroll-spy handles, torn down and rebuilt on each page-load so an
    // observer/listener from a prior route never fires on detached nodes.
    let spyObserver: IntersectionObserver | null = null;
    let spyScrollTarget: Element | Window | null = null;
    let spyOnScroll: (() => void) | null = null;
    let spyWindowBound = false;

    // The section-nav anchors that point at an in-page section on THIS page.
    // Hrefs are absolute ("/#about"); resolve each to its hash and keep only the
    // ones whose target element exists here (all five on home, none elsewhere).
    function sectionLinks() {
      return Array.prototype.slice
        .call(document.querySelectorAll<HTMLAnchorElement>(".section-nav a"))
        .map((a) => {
          let hash = "";
          try {
            hash = new URL(a.href).hash; // "#about"
          } catch (e) {
            hash = "";
          }
          return { a, hash, id: hash ? hash.slice(1) : "" };
        })
        .filter((x) => x.id && document.getElementById(x.id));
    }

    function clearActive() {
      document.querySelectorAll(".section-nav a").forEach((a) => {
        a.classList.remove("active");
        a.removeAttribute("aria-current");
      });
    }

    function markLink(predicate: (a: HTMLAnchorElement) => boolean) {
      let hit = false;
      document
        .querySelectorAll<HTMLAnchorElement>(".section-nav a")
        .forEach((a) => {
          const on = predicate(a);
          a.classList.toggle("active", on);
          if (on) {
            a.setAttribute("aria-current", "true");
            hit = true;
          } else {
            a.removeAttribute("aria-current");
          }
        });
      return hit;
    }

    function isHome() {
      const p = location.pathname;
      return p === "/" || p.endsWith("/index.html") || p === "/index.html";
    }

    // The scrollable ancestor of the home sections, or null when the page itself
    // scrolls (mobile). Desktop gives .content overflow-y:auto + a fixed height.
    function scrollContainer(): Element | null {
      const content = document.querySelector(".content");
      if (!content) return null;
      const oy = getComputedStyle(content).overflowY;
      if (
        (oy === "auto" || oy === "scroll") &&
        content.scrollHeight > content.clientHeight + 4
      ) {
        return content;
      }
      return null;
    }

    function teardownSpy() {
      if (spyObserver) spyObserver.disconnect();
      spyObserver = null;
      if (spyScrollTarget && spyOnScroll) {
        spyScrollTarget.removeEventListener("scroll", spyOnScroll);
      }
      spyScrollTarget = null;
      spyOnScroll = null;
    }

    function initScrollSpy() {
      const links = sectionLinks();
      if (!links.length) return false;
      const sections = links.map((l) => document.getElementById(l.id)!);

      function setActive(id: string) {
        links.forEach(({ a, id: linkId }) => {
          const on = linkId === id;
          a.classList.toggle("active", on);
          if (on) a.setAttribute("aria-current", "true");
          else a.removeAttribute("aria-current");
        });
      }

      const container = scrollContainer();
      if ("IntersectionObserver" in window) {
        spyObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) setActive((entry.target as HTMLElement).id);
            });
          },
          { root: container, rootMargin: "-40% 0px -55% 0px", threshold: 0 }
        );
        sections.forEach((s) => spyObserver!.observe(s));
      }

      const first = sections[0];
      const last = sections[sections.length - 1];
      function edgeGuard() {
        const box = scrollContainer();
        let atBottom: boolean, atTop: boolean;
        if (box) {
          atBottom = box.scrollTop + box.clientHeight >= box.scrollHeight - 2;
          atTop = box.scrollTop <= 2;
        } else {
          const doc = document.documentElement;
          atBottom = window.innerHeight + window.scrollY >= doc.scrollHeight - 2;
          atTop = window.scrollY <= 2;
        }
        if (atBottom) setActive(last.id);
        else if (atTop) setActive(first.id);
      }

      spyScrollTarget = container || window;
      spyOnScroll = edgeGuard;
      spyScrollTarget.addEventListener("scroll", spyOnScroll, { passive: true });
      edgeGuard();

      if (!spyWindowBound) {
        spyWindowBound = true;
        window.addEventListener("load", () => spyOnScroll && spyOnScroll());
        window.addEventListener(
          "resize",
          () => spyOnScroll && spyOnScroll(),
          { passive: true }
        );
      }
      return true;
    }

    // When we land on home carrying a hash (e.g. a section link clicked from a
    // subpage), scroll that section into view. On desktop the sections live
    // inside .content's own scroll box, so a plain browser hash-scroll (which
    // scrolls the window) can miss — scrollIntoView finds the right ancestor.
    function scrollToHash() {
      if (!location.hash) return;
      const el = document.getElementById(location.hash.slice(1));
      if (el) el.scrollIntoView({ block: "start" });
    }

    function init() {
      teardownSpy();
      if (isHome()) {
        clearActive();
        scrollToHash();
        initScrollSpy();
      } else {
        // Current-page marker: Projects-area pages light the Projects nav link.
        const p = location.pathname;
        const projectsArea =
          /(^|\/)(projects|built-with|eclipse-built)\.html$/.test(p);
        clearActive();
        if (projectsArea) {
          markLink((a) => {
            try {
              return new URL(a.href).hash === "#projects";
            } catch (e) {
              return false;
            }
          });
        }
      }
    }

    document.addEventListener("astro:page-load", init);
  </script>

  <script>
    // Tardis time-machine — site-wide (V2.1), moved from index. The .tardis node is
    // transition:persist, so the same node carries across navigations. Two things
    // must survive a swap:
    //   • the spin — re-inserting a persisted node RESTARTS a CSS animation (it would
    //     jump), so the spin is a WAAPI animation whose phase we capture before the
    //     swap and resume after (mirrors the panorama zoom in BaseLayout), keeping it
    //     continuous between pages;
    //   • the click / keyboard wiring — bound so it never stacks on the persisted
    //     node or on document across navigations.
    (function () {
      const REDUCE = window.matchMedia("(prefers-reduced-motion: reduce)");
      const SPIN_MS = 5000; // matches the retired `tardis-spin 5s linear` CSS
      let spin = null;
      let spinTime = 0; // phase (currentTime) carried across a swap

      function startSpin(resumeAt) {
        if (REDUCE.matches) return; // reduced motion: no spin (matches the CSS guard)
        const svg = document.querySelector(".tardis-svg");
        if (!svg || typeof svg.animate !== "function") return;
        // Clear anything the swap's re-insertion may have stranded, so we never
        // stack duplicate spins.
        svg.getAnimations().forEach(function (a) {
          a.cancel();
        });
        spin = svg.animate(
          [{ transform: "rotateY(0deg)" }, { transform: "rotateY(360deg)" }],
          { duration: SPIN_MS, iterations: Infinity, easing: "linear" }
        );
        if (typeof resumeAt === "number" && resumeAt > 0) {
          try {
            spin.currentTime = resumeAt; // pick up the pre-swap phase
          } catch (e) {
            /* older engines: fall back to starting from 0 */
          }
        }
      }

      // Interaction: click toggles the archive panel; Escape / outside-click close.
      // The toggle click binds ONCE (guarded — the node persists, so re-running on
      // every page-load would stack listeners); the document-level listeners tear
      // down before re-adding (document also persists across swaps).
      let tKeydown = null;
      let tDocClick = null;
      function initTardis() {
        const toggle = document.querySelector(".tardis-toggle");
        const panel = document.getElementById("tardis-panel");
        if (!toggle || !panel) return;
        function isOpen() {
          return toggle.getAttribute("aria-expanded") === "true";
        }
        function open() {
          panel.hidden = false;
          toggle.setAttribute("aria-expanded", "true");
        }
        function close(returnFocus) {
          panel.hidden = true;
          toggle.setAttribute("aria-expanded", "false");
          if (returnFocus) toggle.focus();
        }
        if (!toggle.dataset.tardisBound) {
          toggle.addEventListener("click", function () {
            if (isOpen()) close(false);
            else open();
          });
          toggle.dataset.tardisBound = "1";
        }
        if (tKeydown) document.removeEventListener("keydown", tKeydown);
        if (tDocClick) document.removeEventListener("click", tDocClick);
        tKeydown = function (e) {
          if (e.key === "Escape" && isOpen()) close(true);
        };
        tDocClick = function (e) {
          if (isOpen() && !e.target.closest(".tardis")) close(false);
        };
        document.addEventListener("keydown", tKeydown);
        document.addEventListener("click", tDocClick);
      }

      // First load: start the spin. (Interaction is wired by astro:page-load, which
      // also fires on the first load.)
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function () {
          startSpin();
        });
      } else {
        startSpin();
      }
      document.addEventListener("astro:page-load", initTardis);
      // Carry the spin phase across a swap: capture before, resume after (before the
      // browser paints, so there's no visible jump — same as the panorama).
      document.addEventListener("astro:before-swap", function () {
        if (spin) {
          try {
            spinTime = Number(spin.currentTime) || 0;
          } catch (e) {
            spinTime = 0;
          }
        }
      });
      document.addEventListener("astro:after-swap", function () {
        startSpin(spinTime);
      });
    })();
  </script>
</BaseLayout>
